# Copie este arquivo para .env.local e preencha com os valores do seu projeto Supabase.
# Nunca commite o arquivo .env.local — ele já está no .gitignore.

# Encontre estes valores em: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# IMPORTANTE — segurança das chaves:
# As variáveis NEXT_PUBLIC_ são intencionalmente enviadas ao browser.
# A chave "anon/publishable" do Supabase é projetada para ser pública —
# a segurança dos dados é garantida pelas políticas de Row Level Security (RLS).
# NUNCA adicione aqui a "service_role key" — ela dá acesso irrestrito ao banco
# e jamais deve aparecer no código frontend ou ser commitada.
